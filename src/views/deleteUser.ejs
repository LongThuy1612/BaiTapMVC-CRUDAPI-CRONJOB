<!DOCTYPE html>
<html lang="en">  
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Delete A User</title>
</head>
<body>
    <div class="topnav">
        <a href="/user">Home</a>
        <a href="/class">Class</a>
        <a href="/score">Score</a>
        <a href="/user/create">Create Users</a>
    </div>
    <div class = "form-add-new"></div>
        <form action="/user/delete-user" method="POST">
            <fieldset>
                <legend>Delete a user:</legend>
                <div style="display: none;">
                    <label for="id">ID:</label>
                    <input type="text" id="id" name="id" value="<%= user.id %>" readonly>
                </div>
                <div>
                    <label>Are you sure to delete this user with Email: </label>
                    <input type="email" id="email" name="email" value="<%= user.email %>" readonly>
                </div>
                <div>
                    <button>Confirm</button>
                </div>
            </fieldset>
        </form>
    </div>
</body>
</html>